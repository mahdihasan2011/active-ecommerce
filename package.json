{
  "name": "active-ecommerce-monorepo",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "migrate": "pnpm --filter api run prisma:migrate",
    "prisma:generate": "pnpm --filter api run prisma:generate",
    "prisma:studio": "pnpm --filter api exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
